# ─────────────────────────────────────────────
#  ReqRes QA Automation — Environment Variables
#  Copy this file to .env and fill in values.
#  NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────

# Base URL of the API under test
BASE_URL=https://reqres.in

# API prefix (ReqRes uses /api)
API_PREFIX=/api

# API Key if ReqRes required is some endpoints
API_KEY=

# Timeout for each API request in milliseconds
REQUEST_TIMEOUT_MS=10000

# Maximum acceptable response time in milliseconds (SLA)
MAX_RESPONSE_TIME_MS=3000

# ReqRes credentials for auth endpoints
TEST_EMAIL=eve.holt@reqres.in
TEST_PASSWORD=cityslicka

# (Optional) Allure results directory
ALLURE_RESULTS_DIR=allure-results
